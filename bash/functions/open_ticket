#!/usr/bin/env bash
function open-ticket() {
    # TODO: Support reading from stdin

    local DEFAULT_PROJECT="VEGA"
    local JIRA_URL="https://keyloop.atlassian.net"
    if [[ "$#" -eq 0 ]]; then
        echo "Usage: ticket <ticket-id>"
        return 1
    fi
    local TICKET_ID SUFFIX
    for TICKET_ID in "$@"; do
        if [[ "${TICKET_ID}" =~ ^[0-9] ]]; then
            SUFFIX="${DEFAULT_PROJECT}-${TICKET_ID}"
        else
            SUFFIX="${TICKET_ID}"
        fi
        ${BROWSER} "${JIRA_URL}/browse/${SUFFIX}" &> /dev/null
    done
}

alias ticket=open-ticket
